{
    "layer": "bottom", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right": [ "custom/rightfirstborderradius", "custom/media", "custom/media/pause", "pulseaudio", "cpu", "memory", "keyboard-state", "battery", "battery#bat2", "network", "tray", "clock", "custom/wlogout"],
    // Modules configuration
    
    "hyprland/workspaces": {
      "format": "<sup>{icon}</sup> {windows}",
      "on-scroll-up": "hyprctl dispatch workspace e-1",
      "on-scroll-down": "hyprctl dispatch workspace e+1",
      "format-window-separator": " έΑλ ",
      "window-rewrite-default": "ΎΒβ"
      //"window-rewrite": {
      //    "title<.*youtube.*>": "ΎΖς", // Windows whose titles contain "youtube"
      //    "class<firefox>": "ΎΚσ", // Windows whose classes are "firefox"
      //    "class<VencordDesktop>": "ΎΟΤ",
      //    "class<VSCodium>": "ΎΕκ",
      //    "class<Kitty>": "ΎΕι",
      //    "class<firefox> title<.*github.*>": "ΎΕΥ", // Windows whose class is "firefox" and title contains "github". Note that "class" always comes first.
      //    "foot": "ΌηΧ", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
      //    "code": "≤░ρη"
      //}
    },

    "hyprland/window": {
        "separate-outputs": true
    },


    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ΎΑμ",
            "unlocked": "ΎΓε"
        }
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
   
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format" : "{:%d/%m/%Y - %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode-mon-col"  : 3,
            "on-scroll"     : 1,
            "on-click-right": "mode",
            "format": {
                      "months":     "<span color='#ffead3'><b>{}</b></span>",
                      "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                      "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                      "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                      }
            },
        "actions":  {
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
            }
    },
    "cpu": {
        "format": "{usage}% ΎΜδ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% ΎΔΚ"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ΎΩπ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },

    {{   if eq .chezmoi.osRelease.id "arch" }}
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
        "format-ethernet": "\uf796",
        "tooltip-format": "{ipaddr}/{cidr} | {ifname} via {gwaddr} \uf796 | Wireless SigStrength: {signalStrength}% ",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "Disconnected έγι",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    {{   else if eq .chezmoi.osRelease.id "debian" }}
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) \uf1eb",
        "format-ethernet": "\uf1eb",
        "tooltip-format": "{ipaddr}/{cidr} | {ifname} via {gwaddr} \uf1eb | Wireless SigStrength: {signalStrength}% ",
        "format-linked": "{ifname} (No IP) \uf1eb",
        "format-disconnected": "Disconnected έγι",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    {{   end }}

    
    "pulseaudio": {
        "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    //"custom/media": {
    //    "format": "{icon} {}",
    //    "return-type": "json",
    //    "max-length": 40,
    //    "format-icons": {
    //        "spotify": "ΎΗ╝",
    //        "firefox": "ΎΚσΏθΟε",
    //        "default": "ΏθΟε"
    //    },
//
    //    "on-click": "playerctl play-pause",
    //    "on-scroll-up": "playerctl next",
    //    "on-scroll-down": "playerctl previous",
    //    "escape": true,
    //    "tooltip": true,
    //    "tooltip-format": "{icon} {}",
    //    "exec": "/usr/bin/python3 ~/.config/waybar/custom_modules/mediaplayer.py 2> /dev/null" // Script in resources folder
    //    // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    //},
    "custom/rightfirstborderradius": {
        "format": " ",
        "tooltip": false
    },
    "custom/wlogout": {
        "format": "<span foreground=\"black\">\uf011</span>",
        "tooltip": false,
        "on-click": "wlogout"
    }
}

